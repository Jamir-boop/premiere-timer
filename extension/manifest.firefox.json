{
  "manifest_version": 3,
  "name": "Premiere Timer",
  "version": "1.0.0",
  "description": "Local CS2 Premier CS Rating expiry timer using Steam Personal Game Data.",
  "permissions": [
    "activeTab",
    "alarms",
    "scripting",
    "storage"
  ],
  "optional_host_permissions": [
    "https://steamcommunity.com/*"
  ],
  "action": {
    "default_title": "Premiere Timer",
    "default_popup": "popup.html"
  },
  "sidebar_action": {
    "default_title": "Premiere Timer",
    "default_panel": "sidebar.html"
  },
  "commands": {
    "_execute_action": {
      "description": "Open popup"
    },
    "open-sidebar": {
      "description": "Open sidebar"
    }
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  }
}
